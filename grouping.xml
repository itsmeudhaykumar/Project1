<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Master Suite">
    <groups>
        <run>
            <include name="master"/>
            <exclude name="dataDriven"/>
           <!-- <include name="validation"/>
            <include name="master"/>-->
        </run>
    </groups>
    <listeners>
        <listener class-name="utilities.ExtentReportManager"/>
    </listeners>
    <test verbose="2" preserve-order="true" name="Test" thread-count="3">
        <parameter name="os" value="windows"/>
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="testCases.TC001_AgentLoginTest"/>
            <class name="testCases.TC002_LoginValidationTest"/>
        </classes>
    </test>
</suite>